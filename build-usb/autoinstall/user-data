#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us

  # Suppress slow journal flush during install
  early-commands:
    - systemctl mask systemd-journal-flush.service

  # Automatically use the first disk found
  storage:
    layout:
      name: lvm
      sizing-policy: all

  # Network: DHCP on all interfaces
  network:
    version: 2
    ethernets:
      id0:
        match:
          name: "en*"
        dhcp4: true
      id1:
        match:
          name: "eth*"
        dhcp4: true

  # User account
  identity:
    hostname: mfarm-rig
    username: miner
    password: "$6$6mvROTQewCK3GZWQ$1c4qBpc8ZH5vOnJkNu/fMGtsMB9rKFtEIdGqy6f4o.uTZiSGaW3KeTRoSePRGs7sdMEaVxU3GXbKVEh4Em3m2/"

  # SSH
  ssh:
    install-server: true
    allow-pw: true

  # Packages to install during OS setup
  packages:
    - openssh-server
    - python3
    - python3-venv
    - lm-sensors
    - htop
    - screen
    - wget
    - curl
    - net-tools
    - pciutils
    - usbutils
    - smartmontools
    - sysstat
    - nvme-cli
    - linux-headers-generic
    - dkms
    - build-essential

  # Post-install commands (run in the installed system)
  late-commands:
    # Enable root SSH login (mining rigs need this)
    - curtin in-target -- bash -c "echo 'PermitRootLogin yes' >> /etc/ssh/sshd_config"

    # Give miner user sudo without password
    - curtin in-target -- bash -c "echo 'miner ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/miner"

    # Set root password same as miner
    - curtin in-target -- bash -c "echo 'root:mfarm' | chpasswd"

    # Create MFarm directories
    - curtin in-target -- mkdir -p /opt/mfarm /opt/mfarm/miners /etc/mfarm /var/log/mfarm /var/run/mfarm

    # Copy MFarm files from installer media
    - cp /cdrom/mfarm-files/mfarm-agent.py /target/opt/mfarm/mfarm-agent.py
    - cp /cdrom/mfarm-files/miner-wrapper.sh /target/opt/mfarm/miner-wrapper.sh
    - cp /cdrom/mfarm-files/mfarm-agent.service /target/etc/systemd/system/mfarm-agent.service
    - cp /cdrom/mfarm-files/config.json /target/etc/mfarm/config.json
    - cp /cdrom/mfarm-files/mfarm-firstboot.sh /target/opt/mfarm/mfarm-firstboot.sh
    - cp /cdrom/mfarm-files/mfarm-firstboot.service /target/etc/systemd/system/mfarm-firstboot.service
    - chmod +x /target/opt/mfarm/mfarm-agent.py /target/opt/mfarm/miner-wrapper.sh /target/opt/mfarm/mfarm-firstboot.sh

    # Set up logrotate for MFarm
    - |
      cat > /target/etc/logrotate.d/mfarm << 'LOGROTATE'
      /var/log/mfarm/*.log {
          daily
          rotate 7
          compress
          delaycompress
          missingok
          notifempty
          size 50M
      }
      LOGROTATE

    # Enable MFarm services (agent starts after first-boot completes)
    - curtin in-target -- systemctl enable mfarm-firstboot.service

    # Disable unnecessary services for mining rigs
    - curtin in-target -- systemctl disable snapd.service || true
    - curtin in-target -- systemctl disable snapd.socket || true
    - curtin in-target -- systemctl disable multipathd.service || true
    - curtin in-target -- systemctl disable apparmor.service || true
    - curtin in-target -- systemctl disable ufw.service || true

    # Optimize for mining: disable sleep/suspend
    - curtin in-target -- systemctl mask sleep.target suspend.target hibernate.target hybrid-sleep.target

    # Set performance governor on boot
    - |
      cat > /target/etc/rc.local << 'RCLOCAL'
      #!/bin/bash
      # Set CPU governor to performance
      for cpu in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
          echo performance > "$cpu" 2>/dev/null
      done
      # Disable GPU ECC (wastes memory/performance on mining)
      nvidia-smi --ecc-config=0 2>/dev/null || true
      exit 0
      RCLOCAL
    - chmod +x /target/etc/rc.local

    # Network: enable all ethernet interfaces with DHCP
    - |
      cat > /target/etc/netplan/99-mfarm.yaml << 'NETPLAN'
      network:
        version: 2
        renderer: networkd
        ethernets:
          all-en:
            match:
              name: "en*"
            dhcp4: true
          all-eth:
            match:
              name: "eth*"
            dhcp4: true
      NETPLAN

    # Set timezone to UTC (mining rigs don't need local time)
    - curtin in-target -- timedatectl set-timezone UTC

    # Increase file descriptor limits
    - |
      cat >> /target/etc/security/limits.conf << 'LIMITS'
      *    soft    nofile    65535
      *    hard    nofile    65535
      LIMITS
